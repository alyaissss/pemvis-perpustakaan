	<parameter name="id_kembali" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT 
    p.id_kembali, 
    p.tgl_nota AS tanggal_kembali, 
    p.denda, 
    p.id_nota,
    pt.nama_petugas,
    i.id_buku,
    b.judul,
    b.penulis,
    b.penerbit,
    b.kategori
FROM pengembalian p
LEFT JOIN petugas pt ON p.id_petugas = pt.id_petugas
LEFT JOIN isi i ON p.id_nota = i.id_nota
LEFT JOIN buku b ON i.id_buku = b.id_buku
WHERE p.id_kembali = $P{id_kembali}]]>
	</queryString>
