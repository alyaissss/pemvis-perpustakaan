<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="null" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="519c1f93-fd5a-4699-b690-4246d40b43f2">
	<property name="ireport.zoom" value="1.2100000000000006"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="id_denda" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
     anggota.`id_anggota` AS anggota_id_anggota,
     anggota.`nama_anggota` AS anggota_nama_anggota,
     anggota.`jk` AS anggota_jk,
     anggota.`kelas` AS anggota_kelas,
     anggota.`tgl_registrasi` AS anggota_tgl_registrasi,

     buku.`id_buku` AS buku_id_buku,
     buku.`isbn` AS buku_isbn,
     buku.`judul` AS buku_judul,
     buku.`penulis` AS buku_penulis,
     buku.`penerbit` AS buku_penerbit,
     buku.`tahun` AS buku_tahun,
     buku.`kategori` AS buku_kategori,
     buku.`stok` AS buku_stok,

     denda.`id_denda` AS denda_id_denda,
     DATE_FORMAT(denda.`tgl_pembayaran`,'%d/%m/%Y') AS denda_tgl_pembayaran,
     denda.`jumlah_denda` AS denda_jumlah_denda,
     denda.`id_kembali` AS denda_id_kembali,
     denda.`id_petugas` AS denda_id_petugas,

     isi.`id_nota` AS isi_id_nota,
     isi.`id_buku` AS isi_id_buku,

     nota.`id_nota` AS nota_id_nota,
     DATE_FORMAT(nota.`tgl_nota`,'%d/%m/%Y') AS nota_tgl_nota,
     nota.`id_anggota` AS nota_id_anggota,
     nota.`id_petugas` AS nota_id_petugas,
     DATE_FORMAT(nota.`jatuh_tempo`,'%d/%m/%Y') AS nota_jatuh_tempo,

     pengembalian.`id_kembali` AS pengembalian_id_kembali,
     DATE_FORMAT(pengembalian.`tgl_nota`,'%d/%m/%Y') AS pengembalian_tgl_nota,
     pengembalian.`denda` AS pengembalian_denda,
     pengembalian.`id_nota` AS pengembalian_id_nota,
     pengembalian.`id_petugas` AS pengembalian_id_petugas,

     petugas.`id_petugas` AS petugas_id_petugas,
     petugas.`nama_petugas` AS petugas_nama_petugas,
     petugas.`jk` AS petugas_jk,
     petugas.`no_telp` AS petugas_no_telp,
     petugas.`alamat` AS petugas_alamat,
     petugas.`password` AS petugas_password

FROM
     `denda` denda
     INNER JOIN `pengembalian` pengembalian
          ON denda.`id_kembali` = pengembalian.`id_kembali`
     INNER JOIN `nota` nota
          ON pengembalian.`id_nota` = nota.`id_nota`
     INNER JOIN `isi` isi
          ON nota.`id_nota` = isi.`id_nota`
     INNER JOIN `buku` buku
          ON isi.`id_buku` = buku.`id_buku`
     INNER JOIN `anggota` anggota
          ON nota.`id_anggota` = anggota.`id_anggota`
     INNER JOIN `petugas` petugas
          ON denda.`id_petugas` = petugas.`id_petugas`

WHERE
     TRIM(denda.`id_denda`) = TRIM($P{id_denda})]]>
	</queryString>
