	<property name="ireport.y" value="0"/>
	<parameter name="id_nota" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
     anggota.`id_anggota` AS anggota_id_anggota,
     anggota.`nama_anggota` AS anggota_nama_anggota,
     anggota.`jk` AS anggota_jk,
     anggota.`kelas` AS anggota_kelas,
     anggota.`tgl_registrasi` AS anggota_tgl_registrasi,
     buku.`id_buku` AS buku_id_buku,
     buku.`isbn` AS buku_isbn,
     buku.`judul` AS buku_judul,
     buku.`penulis` AS buku_penulis,
     buku.`penerbit` AS buku_penerbit,
     buku.`tahun` AS buku_tahun,
     buku.`kategori` AS buku_kategori,
     buku.`stok` AS buku_stok,
     isi.`id_nota` AS isi_id_nota,
     isi.`id_buku` AS isi_id_buku,
     nota.`id_nota` AS nota_id_nota,
     nota.`tgl_nota` AS nota_tgl_nota,
     nota.`id_anggota` AS nota_id_anggota,
     nota.`id_petugas` AS nota_id_petugas,
     nota.`jatuh_tempo` AS nota_jatuh_tempo,
     petugas.`id_petugas` AS petugas_id_petugas,
     petugas.`nama_petugas` AS petugas_nama_petugas
FROM
     `nota` nota
     INNER JOIN `isi` isi ON nota.`id_nota` = isi.`id_nota`
     INNER JOIN `buku` buku ON isi.`id_buku` = buku.`id_buku`
     INNER JOIN `anggota` anggota ON nota.`id_anggota` = anggota.`id_anggota`
     INNER JOIN `petugas` petugas ON nota.`id_petugas` = petugas.`id_petugas`
WHERE 
     TRIM(nota.`id_nota`) = TRIM($P{id_nota})]]>
	</queryString>
